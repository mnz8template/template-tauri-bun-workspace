{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "template-tauri-bun-workspace",
  "version": "0.0.1",
  "identifier": "com.template-tauri-bun-workspace",
  "build": {
    "frontendDist": "../ui-desktop/dist",
    "devUrl": "http://localhost:25000",
    "beforeDevCommand": "bun -F ui-desktop dev",
    "beforeBuildCommand": "bun -F ui-desktop build"
  },
  "app": {
    "windows": [
      {
        "title": "template-tauri-bun-workspace",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"]
  }
}
